#!/bin/bash
set -e

ACTION="${1:-configure}"
OLD_VERSION="${2:-}"

# ---------------------------------------------------------------------------
# System setup — runs on every install/upgrade
# ---------------------------------------------------------------------------
setup_system() {
    if ! getent group ox_webservice >/dev/null; then
        groupadd --system ox_webservice
    fi
    if ! getent passwd ox_webservice >/dev/null; then
        useradd --system \
                -g ox_webservice \
                -d /var/lib/ox_webservice \
                -s /usr/sbin/nologin \
                ox_webservice
    fi

    mkdir -p /etc/pki/ox_webservice/private/default \
             /etc/pki/ox_webservice/ca \
             /etc/pki/ox_webservice/tls
    chmod 750 /etc/pki/ox_webservice/private \
              /etc/pki/ox_webservice/tls
    chmod 770 /etc/pki/ox_webservice/private/default
    chmod 775 /etc/pki/ox_webservice/ca
    chown root:ox_webservice /etc/pki/ox_webservice/private \
                             /etc/pki/ox_webservice/private/default \
                             /etc/pki/ox_webservice/tls \
                             /etc/pki/ox_webservice/ca

    chown -R root:ox_webservice /etc/ox_webservice
    chmod 750 /etc/ox_webservice
    find /etc/ox_webservice -type f -exec chmod 640 {} \;

    mkdir -p /var/lib/ox_webservice /var/log/ox_webservice /var/run/ox_webservice
    chown ox_webservice:ox_webservice /var/lib/ox_webservice /var/log/ox_webservice /var/run/ox_webservice
    chmod 750 /var/lib/ox_webservice /var/log/ox_webservice
    chmod 755 /var/run/ox_webservice

    if [ -d /run/systemd/system ]; then
        systemctl daemon-reload
        systemctl enable ox_webservice.service || true
    fi
}

# ---------------------------------------------------------------------------
# CA setup — fresh install only
# Accepts parameters interactively or via environment variables / answers file.
#
# Answers file (OX_CA_ANSWERS_FILE): shell-syntax file that sets any of:
#   OX_CA_CERT_TYPE      1 (self-signed root CA) or 2 (CSR)  [default: 1]
#   OX_CA_HOSTNAME       FQDN of the CA server               [required]
#   OX_CA_CN             Common Name                         [default: hostname label]
#   OX_CA_ORGANIZATION   Organization (O)
#   OX_CA_OU             Organizational Unit (OU)
#   OX_CA_LOCALITY       City / Locality (L)
#   OX_CA_STATE          State or Province (ST)
#   OX_CA_COUNTRY        Two-letter country code (C)         [default: US]
#   OX_CA_DOMAIN         Domain for DC= components           [default: derived from FQDN]
#   OX_CA_KEY_PASS       CA key passphrase                   [default: none]
#   OX_CA_CSR_SERVER     Parent ox CA URL for automatic CSR submission (type 2 only)
#   OX_CA_CSR_SERVER_CACERT  Path to parent CA's TLS certificate for verification
# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# Submit the generated CSR to a parent ox CA and install the signed certificate.
# Returns 0 on success, 1 on failure (caller falls back to manual instructions).
# Expects OX_CA_KEY_PASS to be exported if the CA key is passphrase-protected.
# ---------------------------------------------------------------------------
submit_csr() {
    local server="$1"
    # Ensure the server URL has a scheme; default to https://
    [[ "$server" != http://* && "$server" != https://* ]] && server="https://${server}"
    # Strip trailing slash
    server="${server%/}"
    local csr_file="/etc/pki/ox_webservice/ca/root.csr"
    local tmp_body tmp_resp tmp_cert
    tmp_body=$(mktemp /tmp/ox_csr_req.XXXXXX.json)
    tmp_resp=$(mktemp /tmp/ox_csr_resp.XXXXXX.json)
    tmp_cert=$(mktemp /tmp/ox_signed_cert.XXXXXX.pem)

    echo ""
    echo "Submitting CSR to ${server}..."

    # TLS verification for the parent CA's HTTPS endpoint
    local curl_tls=()
    if [[ -n "${OX_CA_CSR_SERVER_CACERT:-}" && -f "${OX_CA_CSR_SERVER_CACERT}" ]]; then
        curl_tls=(--cacert "$OX_CA_CSR_SERVER_CACERT")
    else
        echo "  Warning: OX_CA_CSR_SERVER_CACERT not set — parent CA TLS will not be verified."
        curl_tls=(-k)
    fi

    # Build JSON request body (python3 handles PEM escaping; jq as fallback)
    python3 -c "
import json, sys
with open('${csr_file}') as f:
    csr = f.read()
print(json.dumps({'csr_pem': csr}))
" > "$tmp_body" 2>/dev/null \
    || jq -n --rawfile csr_pem "${csr_file}" \
           '{"csr_pem": $csr_pem}' \
           > "$tmp_body" 2>/dev/null \
    || { echo "  Cannot build request body: install python3 or jq."; rm -f "$tmp_body" "$tmp_resp" "$tmp_cert"; return 1; }

    local http_code
    http_code=$(curl -s \
        "${curl_tls[@]}" \
        -o "$tmp_resp" \
        -w "%{http_code}" \
        -X POST \
        "${server}/api/v1/ca/cross-sign" \
        -H "Content-Type: application/json" \
        --data-binary "@${tmp_body}")
    rm -f "$tmp_body"

    if [[ "$http_code" != "200" && "$http_code" != "201" ]]; then
        echo "  CSR submission failed (HTTP ${http_code}):"
        cat "$tmp_resp" 2>/dev/null || echo "  (no response body)"
        echo "  (check /tmp/ox_cross_sign_error.txt on the root CA for details)"
        rm -f "$tmp_resp" "$tmp_cert"
        return 1
    fi

    # Extract signed certificate PEM from response JSON (data.pem)
    python3 -c "
import json, sys
with open('${tmp_resp}') as f:
    d = json.load(f)
cert = (d.get('data') or d).get('pem', '').strip()
if not cert:
    sys.exit(1)
print(cert)
" > "$tmp_cert" 2>/dev/null \
    || { rm -f "$tmp_resp" "$tmp_cert"; echo "  Could not extract certificate from response."; return 1; }
    rm -f "$tmp_resp"

    [[ -s "$tmp_cert" ]] || { rm -f "$tmp_cert"; echo "  Empty certificate in response."; return 1; }

    echo "  Certificate received. Installing..."
    /usr/share/ox_webservice/install-ca-cert.sh "$tmp_cert" \
        --content-dir "/usr/share/ox_webservice/content/www/ca" \
        --start 2>&1
    local rc=$?
    rm -f "$tmp_cert"
    return $rc
}

# ---------------------------------------------------------------------------
setup_ca() {
    # Load answers file if provided — parsed as KEY=VALUE pairs so unquoted
    # values with spaces work without the user needing to quote them.
    if [[ -n "${OX_CA_ANSWERS_FILE:-}" && -r "${OX_CA_ANSWERS_FILE}" ]]; then
        while IFS= read -r line || [[ -n "$line" ]]; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue   # skip comments
            [[ -z "${line//[[:space:]]/}" ]] && continue  # skip blank lines
            if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
                local _key="${BASH_REMATCH[1]}"
                local _val="${BASH_REMATCH[2]}"
                # Strip a single layer of surrounding quotes if present
                if [[ "$_val" =~ ^\"(.*)\"$ ]] || [[ "$_val" =~ ^\'(.*)\'$ ]]; then
                    _val="${BASH_REMATCH[1]}"
                fi
                printf -v "$_key" '%s' "$_val"
                export "$_key"
            fi
        done < "$OX_CA_ANSWERS_FILE"
    fi

    CSR_SERVER="" CERT_TYPE="" CA_HOSTNAME="" CN="" O="" OU="" L="" ST="" C="" DC_COMPONENTS="" SUBJECT="" PASSPHRASE=""
    GENERATE_ARGS=""

    if [ ! -t 0 ] || [ "${DEBIAN_FRONTEND:-}" = "noninteractive" ]; then
        # --- Non-interactive path ---
        if [[ -z "${OX_CA_HOSTNAME:-}" ]]; then
            echo ""
            echo "Non-interactive install: run 'sudo /usr/share/ox_webservice/setup-ca.sh' to complete CA setup."
            echo ""
            return 0
        fi

        CSR_SERVER="${OX_CA_CSR_SERVER:-}"
        CERT_TYPE="${OX_CA_CERT_TYPE:-1}"
        CA_HOSTNAME="$OX_CA_HOSTNAME"

        CN_DEFAULT="${CA_HOSTNAME%%.*}"
        DC_DEFAULT=""
        [[ "$CA_HOSTNAME" == *"."* ]] && DC_DEFAULT="${CA_HOSTNAME#*.}"

        CN="${OX_CA_CN:-$CN_DEFAULT}"
        O="${OX_CA_ORGANIZATION:-}"
        OU="${OX_CA_OU:-}"
        L="${OX_CA_LOCALITY:-}"
        ST="${OX_CA_STATE:-}"
        C="${OX_CA_COUNTRY:-US}"
        PASSPHRASE="${OX_CA_KEY_PASS:-}"
        DC_INPUT="${OX_CA_DOMAIN:-$DC_DEFAULT}"

        DC_COMPONENTS=""
        if [[ -n "$DC_INPUT" ]]; then
            IFS='.' read -ra DC_PARTS <<< "$DC_INPUT"
            for PART in "${DC_PARTS[@]}"; do
                [[ -n "$PART" ]] && DC_COMPONENTS="${DC_COMPONENTS:+${DC_COMPONENTS},}DC=${PART}"
            done
        fi

        SUBJECT="CN=${CN}"
        [[ -n "$O" ]]             && SUBJECT="${SUBJECT},O=${O}"
        [[ -n "$OU" ]]            && SUBJECT="${SUBJECT},OU=${OU}"
        [[ -n "$L" ]]             && SUBJECT="${SUBJECT},L=${L}"
        [[ -n "$ST" ]]            && SUBJECT="${SUBJECT},ST=${ST}"
        SUBJECT="${SUBJECT},C=${C}"
        [[ -n "$DC_COMPONENTS" ]] && SUBJECT="${SUBJECT},${DC_COMPONENTS}"

        GENERATE_ARGS="--force"

    else
        # --- Interactive path ---
        echo ""
        echo "ox Certificate Authority Setup"
        echo "================================"
        echo ""

        # Input collection loop — repeats until user confirms all settings
        while true; do

        # Certificate type
        echo "Certificate type:"
        echo "  1) Self-signed root CA  (standalone, no external CA required)"
        echo "  2) Certificate signing request (CSR)  (subordinate CA signed by an existing root CA)"
        echo ""
        CERT_TYPE=""
        while [[ "$CERT_TYPE" != "1" && "$CERT_TYPE" != "2" ]]; do
            read -rp "Choice [1/2]: " CERT_TYPE
        done

        # Parent CA URL (type 2 only — optional automatic submission)
        CSR_SERVER=""
        if [[ "$CERT_TYPE" == "2" ]]; then
            echo ""
            echo "  To submit the CSR automatically, provide the URL of the parent ox CA."
            echo "  Leave blank to submit the CSR manually after installation."
            read -rp "Parent CA URL (e.g. https://root-ca.example.com): " CSR_SERVER
        fi

        # CA hostname (FQDN — used to configure plugin URLs, not part of the cert subject)
        echo ""
        while true; do
            read -rp "CA fully qualified domain name (e.g. ca.example.com): " CA_HOSTNAME
            [[ -n "$CA_HOSTNAME" ]] && break
            echo "  Hostname is required."
        done

        # Derive CN and domain from FQDN
        CN_DEFAULT="${CA_HOSTNAME%%.*}"
        if [[ "$CA_HOSTNAME" == *"."* ]]; then
            DC_DEFAULT="${CA_HOSTNAME#*.}"
        else
            DC_DEFAULT=""
        fi

        # Certificate fields
        echo ""
        echo "Certificate information:"

        echo ""
        echo "  (Common Name) Name of the person, server, or device."
        read -rp "Host name without domain [${CN_DEFAULT}]: " CN_INPUT
        CN="${CN_INPUT:-$CN_DEFAULT}"

        echo ""
        echo "  (Organization) The legal name of the company or entity."
        read -rp "Organization Name: " O

        echo ""
        echo "  (Organizational Unit) The specific department or division (e.g., 'IT Support' or 'Engineering')."
        read -rp "Department or Division: " OU

        echo ""
        echo "  (Locality) The city or local area where the entity is located."
        read -rp "City: " L

        echo ""
        echo "  (State or Province) The full name of the state or province (not abbreviated)."
        read -rp "Full name of state or province: " ST

        echo ""
        echo "  (Country) A two-letter country code (e.g., US or UK)."
        C="US"
        while true; do
            read -rp "2 Letter Country Code [US]: " C_INPUT
            C="${C_INPUT:-US}"
            [[ "${#C}" -eq 2 ]] && break
            echo "  Country must be exactly 2 letters."
        done

        echo ""
        echo "  (Domain Component) The domain name is split into dc= components for directory lookups."
        echo "  Example: 'justlikeef.com' becomes DC=justlikeef,DC=com — leave blank to omit."
        if [[ -n "$DC_DEFAULT" ]]; then
            echo "  Derived from your hostname: ${DC_DEFAULT}"
        fi
        read -rp "Domain Name [${DC_DEFAULT}]: " DC_INPUT_ENTERED
        DC_INPUT="${DC_INPUT_ENTERED:-$DC_DEFAULT}"

        # Parse DC into components
        DC_COMPONENTS=""
        if [[ -n "$DC_INPUT" ]]; then
            IFS='.' read -ra DC_PARTS <<< "$DC_INPUT"
            for PART in "${DC_PARTS[@]}"; do
                [[ -n "$PART" ]] && DC_COMPONENTS="${DC_COMPONENTS:+${DC_COMPONENTS},}DC=${PART}"
            done
        fi

        # Build subject DN
        SUBJECT="CN=${CN}"
        [[ -n "$O" ]]             && SUBJECT="${SUBJECT},O=${O}"
        [[ -n "$OU" ]]            && SUBJECT="${SUBJECT},OU=${OU}"
        [[ -n "$L" ]]             && SUBJECT="${SUBJECT},L=${L}"
        [[ -n "$ST" ]]            && SUBJECT="${SUBJECT},ST=${ST}"
        SUBJECT="${SUBJECT},C=${C}"
        [[ -n "$DC_COMPONENTS" ]] && SUBJECT="${SUBJECT},${DC_COMPONENTS}"

        # Passphrase
        echo ""
        echo "CA key passphrase (press Enter for no passphrase):"
        PASSPHRASE=""
        while true; do
            read -rsp "  Passphrase: " PASSPHRASE; echo
            [[ -z "$PASSPHRASE" ]] && break
            read -rsp "  Confirm:    " PASSPHRASE2; echo
            [[ "$PASSPHRASE" == "$PASSPHRASE2" ]] && break
            echo "  Passphrases do not match — try again."
        done

        # Summary and confirmation
        echo ""
        echo "----------------------------------------"
        echo "Certificate Authority Configuration"
        echo "----------------------------------------"
        if [[ "$CERT_TYPE" == "1" ]]; then
            echo "  Type:             Self-signed root CA"
        else
            echo "  Type:             Certificate signing request (subordinate CA)"
            if [[ -n "$CSR_SERVER" ]]; then
                echo "  Parent CA URL:    ${CSR_SERVER}"
            else
                echo "  Parent CA URL:    <submit manually>"
            fi
        fi
        echo "  CA FQDN:          ${CA_HOSTNAME}"
        echo ""
        echo "  Common Name:      ${CN}"
        echo "  Organization:     ${O:-<not set>}"
        echo "  Department:       ${OU:-<not set>}"
        echo "  City:             ${L:-<not set>}"
        echo "  State/Province:   ${ST:-<not set>}"
        echo "  Country:          ${C}"
        if [[ -n "$DC_COMPONENTS" ]]; then
            echo "  Domain (DC):      ${DC_COMPONENTS}"
        else
            echo "  Domain (DC):      <not set>"
        fi
        echo ""
        echo "  Subject DN:       ${SUBJECT}"
        echo ""
        if [[ -n "$PASSPHRASE" ]]; then
            echo "  Passphrase:       set"
        else
            echo "  Passphrase:       none"
        fi
        echo "----------------------------------------"
        echo ""
        read -rp "Proceed with these settings? [Y/n]: " CONFIRM
        case "${CONFIRM,,}" in
            ""|y|yes) break ;;
            *)
                echo ""
                echo "Starting over..."
                echo ""
                ;;
        esac

        done  # end confirmation loop
    fi

    # ---------------------------------------------------------------------------
    # Common setup — runs for both interactive and non-interactive paths
    # ---------------------------------------------------------------------------

    # Compute TLS SAN — include both short hostname and FQDN when FQDN contains a dot
    SHORT_HOST="${CA_HOSTNAME%%.*}"
    if [[ "$SHORT_HOST" != "$CA_HOSTNAME" ]]; then
        TLS_SAN="subjectAltName=DNS:${SHORT_HOST},DNS:${CA_HOSTNAME}"
    else
        TLS_SAN="subjectAltName=DNS:${CA_HOSTNAME}"
    fi

    # Configure hostname in plugin configs
    echo ""
    echo "Configuring CA hostname in plugin configs..."
    find /etc/ox_webservice -name "*.yaml" -exec sed -i "s|YOUR_CA_HOSTNAME|${CA_HOSTNAME}|g" {} \;

    # Build TLS certificate subject — same org details as the CA, FQDN as CN
    local tls_subj="/CN=${CA_HOSTNAME}"
    [[ -n "$O" ]]  && tls_subj="${tls_subj}/O=${O}"
    [[ -n "$OU" ]] && tls_subj="${tls_subj}/OU=${OU}"
    [[ -n "$L" ]]  && tls_subj="${tls_subj}/L=${L}"
    [[ -n "$ST" ]] && tls_subj="${tls_subj}/ST=${ST}"
    [[ -n "$C" ]]  && tls_subj="${tls_subj}/C=${C}"
    # DC components derived from hostname domain (host.example.com → DC=example/DC=com)
    local _tls_domain="${CA_HOSTNAME#*.}"
    IFS='.' read -ra _tls_dc <<< "$_tls_domain"
    for _tls_dc_part in "${_tls_dc[@]}"; do
        tls_subj="${tls_subj}/DC=${_tls_dc_part}"
    done
    unset _tls_domain _tls_dc _tls_dc_part

    # Generate self-signed TLS certificate for the HTTPS listener
    # (Replaced by a CA-signed cert below once the CA is ready)
    echo "Generating self-signed TLS certificate for HTTPS listener..."
    openssl req -x509 -newkey rsa:2048 -nodes \
        -keyout /etc/pki/ox_webservice/tls/server.key \
        -out    /etc/pki/ox_webservice/tls/server.crt \
        -days 3650 \
        -subj "$tls_subj" \
        -addext "$TLS_SAN" \
        2>/dev/null
    chmod 640 /etc/pki/ox_webservice/tls/server.crt \
              /etc/pki/ox_webservice/tls/server.key
    chown root:ox_webservice /etc/pki/ox_webservice/tls/server.crt \
                             /etc/pki/ox_webservice/tls/server.key

    # Write env file — passphrase via env var, never on the command line
    if [[ -n "$PASSPHRASE" ]]; then
        printf 'OX_CA_KEY_PASS=%s\n' "$PASSPHRASE" > /etc/ox_webservice/env
    else
        printf '# OX_CA_KEY_PASS=\n' > /etc/ox_webservice/env
    fi
    chmod 600 /etc/ox_webservice/env
    chown root:ox_webservice /etc/ox_webservice/env

    export OX_CA_KEY_PASS="$PASSPHRASE"

    if [[ "$CERT_TYPE" == "2" ]]; then
        echo "Generating CA key and certificate signing request..."
        # shellcheck disable=SC2086
        /usr/share/ox_webservice/generate-root-ca.sh \
            --subject     "$SUBJECT" \
            --hostname    "$CA_HOSTNAME" \
            --content-dir "/usr/share/ox_webservice/content/www/ca" \
            --csr-only \
            $GENERATE_ARGS

        if [[ -n "$CSR_SERVER" ]]; then
            # Download the parent CA cert (TOFU bootstrap) so HTTPS to the parent CA
            # can be verified without -k on this and future runs.
            local parent_cert="/etc/pki/ox_webservice/ca/parent-root-ca.crt"
            if [[ -z "${OX_CA_CSR_SERVER_CACERT:-}" || ! -f "${OX_CA_CSR_SERVER_CACERT}" ]]; then
                local dl_server="$CSR_SERVER"
                [[ "$dl_server" != http://* && "$dl_server" != https://* ]] && dl_server="https://${dl_server}"
                dl_server="${dl_server%/}"
                echo "Downloading parent CA certificate (trust-on-first-use bootstrap)..."
                if curl -s -k --max-time 15 "${dl_server}/ca/root.crt" -o "$parent_cert" 2>/dev/null \
                   && openssl x509 -in "$parent_cert" -noout 2>/dev/null; then
                    export OX_CA_CSR_SERVER_CACERT="$parent_cert"
                    printf 'OX_CA_CSR_SERVER_CACERT=%s\n' "$parent_cert" >> /etc/ox_webservice/env
                    echo "  Parent CA cert saved: $parent_cert"
                else
                    rm -f "$parent_cert"
                    echo "  Warning: could not download parent CA cert — TLS will not be verified."
                fi
            fi

            # OX_CA_KEY_PASS still exported — needed by install-ca-cert.sh for key verification
            if submit_csr "$CSR_SERVER"; then
                unset OX_CA_KEY_PASS
                # Re-sign the TLS certificate with the now-installed ICA CA key so browsers
                # can verify HTTPS using the trusted root CA.  Append the ICA CA cert to form
                # a chain; rustls reads all PEM certs in server.crt and sends them during the
                # TLS handshake, allowing clients to build the full trust path.
                echo "Signing ICA TLS certificate with CA key..."
                local ica_tls_csr ica_tls_signed_pem ica_tls_signed=false
                ica_tls_csr=$(mktemp /tmp/ox_ica_tls.XXXXXX.pem)
                ica_tls_signed_pem=$(mktemp /tmp/ox_ica_tls_signed.XXXXXX.pem)
                if openssl req -new \
                       -key /etc/pki/ox_webservice/tls/server.key \
                       -subj "$tls_subj" \
                       -out "$ica_tls_csr" 2>/dev/null; then
                    if openssl x509 -req -in "$ica_tls_csr" \
                           -CA    /etc/pki/ox_webservice/ca/root.crt \
                           -CAkey /etc/pki/ox_webservice/private/default/ca-root.key.pem \
                           -CAcreateserial \
                           -out "$ica_tls_signed_pem" \
                           -days 3650 \
                           -extfile <(printf "%s\n" "$TLS_SAN") 2>/dev/null; then
                        # Chain: ICA TLS cert + ICA CA cert (rustls sends both)
                        cat "$ica_tls_signed_pem" /etc/pki/ox_webservice/ca/root.crt \
                            > /etc/pki/ox_webservice/tls/server.crt
                        chmod 640 /etc/pki/ox_webservice/tls/server.crt
                        ica_tls_signed=true
                    fi
                fi
                rm -f "$ica_tls_csr" "$ica_tls_signed_pem"
                if [[ "$ica_tls_signed" == true ]]; then
                    echo "  ICA TLS certificate signed — restarting service with new cert..."
                    if [ -d /run/systemd/system ]; then
                        systemctl restart ox_webservice.service 2>/dev/null || true
                    fi
                    echo "  Done."
                else
                    echo "  Warning: could not sign ICA TLS cert — HTTPS uses self-signed fallback."
                fi
            else
                unset OX_CA_KEY_PASS
                echo ""
                echo "Automatic submission failed. Submit the CSR manually:"
                echo "  1. Submit:  /etc/pki/ox_webservice/ca/root.csr"
                echo "  2. Install: sudo /usr/share/ox_webservice/install-ca-cert.sh <signed.crt> --start"
                echo ""
            fi
        else
            unset OX_CA_KEY_PASS
            echo ""
            echo "CSR generated. Next steps:"
            echo "  1. Submit the CSR to your root CA:"
            echo "       /etc/pki/ox_webservice/ca/root.csr"
            echo "  2. When you receive the signed certificate, install it with:"
            echo "       sudo /usr/share/ox_webservice/install-ca-cert.sh <signed.crt>"
            echo "     If your CA also provides the issuing chain:"
            echo "       sudo /usr/share/ox_webservice/install-ca-cert.sh <signed.crt> --chain <chain.pem>"
            echo "     To start the service automatically after installation:"
            echo "       sudo /usr/share/ox_webservice/install-ca-cert.sh <signed.crt> --start"
            echo ""
        fi
    else
        echo "Generating self-signed root CA..."
        # shellcheck disable=SC2086
        /usr/share/ox_webservice/generate-root-ca.sh \
            --subject     "$SUBJECT" \
            --hostname    "$CA_HOSTNAME" \
            --content-dir "/usr/share/ox_webservice/content/www/ca" \
            $GENERATE_ARGS

        # Re-sign the TLS certificate with the root CA so subordinate CAs can
        # verify HTTPS connections using only the root CA cert (TOFU bootstrap).
        echo "Signing TLS certificate with root CA..."
        local tls_csr tls_signed=false
        tls_csr=$(mktemp /tmp/ox_tls_csr.XXXXXX.pem)
        if openssl req -new \
               -key /etc/pki/ox_webservice/tls/server.key \
               -subj "$tls_subj" \
               -out "$tls_csr" 2>/dev/null; then
            local passin_args=()
            [[ -n "${OX_CA_KEY_PASS:-}" ]] && passin_args=(-passin env:OX_CA_KEY_PASS)
            if openssl x509 -req -in "$tls_csr" \
                   -CA    /etc/pki/ox_webservice/ca/root.crt \
                   -CAkey /etc/pki/ox_webservice/private/default/ca-root.key.pem \
                   "${passin_args[@]}" \
                   -CAcreateserial \
                   -out /etc/pki/ox_webservice/tls/server.crt \
                   -days 3650 \
                   -extfile <(printf "%s\n" "$TLS_SAN") 2>/dev/null; then
                tls_signed=true
            fi
        fi
        rm -f "$tls_csr"
        if [[ "$tls_signed" == true ]]; then
            echo "  TLS certificate signed by root CA."
        else
            echo "  Warning: could not sign TLS with root CA — using self-signed fallback."
        fi

        unset OX_CA_KEY_PASS
        echo "Starting ox_webservice..."
        if [ -d /run/systemd/system ]; then
            systemctl start ox_webservice.service
        fi
        echo ""
        echo "ox Certificate Authority is running."
        echo "  Root CA certificate: https://${CA_HOSTNAME}/ca/root.crt"
        if [[ "$tls_signed" == true ]]; then
            echo "  Note: HTTPS is served with a certificate signed by this root CA."
            echo "        Install the root CA certificate in your browser/OS to trust it."
        else
            echo "  Note: HTTPS uses a self-signed certificate — accept the browser warning"
            echo "        or replace /etc/pki/ox_webservice/tls/ with a trusted certificate."
        fi
        echo ""
    fi
}

# ---------------------------------------------------------------------------
case "$ACTION" in
    configure)
        setup_system
        [[ -z "$OLD_VERSION" ]] && setup_ca
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
esac

exit 0
